from Bio import Entrez, SeqIO

# NCBI requires an email to identify who is making requests
Entrez.email = "your_email@example.com"  # <-- replace with your real email


def search_aire_gene(database: str = "nucleotide", retmax: int = 5):
    """
    Search NCBI for AIRE gene records in humans.

    Returns a list of NCBI record IDs matching the search term.
    """
    query = "AIRE[Gene] AND Homo sapiens[Organism]"
    handle = Entrez.esearch(db=database, term=query, retmax=retmax)
    record = Entrez.read(handle)
    handle.close()

    id_list = record["IdList"]
    print(f"Found {len(id_list)} AIRE gene record(s): {id_list}")
    return id_list


